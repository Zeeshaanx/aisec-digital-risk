# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=media_intel

# Database URLs (auto-set by start script, override if needed)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/media_intel
DATABASE_URL_SYNC=postgresql://postgres:postgres@127.0.0.1:5432/media_intel

# OpenAI
OPENAI_API_KEY=your-key-here

# SearXNG
SEARXNG_URL=http://127.0.0.1:8080/

# App
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
